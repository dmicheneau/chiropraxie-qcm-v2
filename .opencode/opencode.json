{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    // https://github.com/azrod/memoai
    "memoai": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "MEMOAI_PROJECT=chiropraxiv2",
        "-v",
        "memoai_memoai-data:/data/.memoai",
        // "--name",
        // "chiropraxiV2-memoai-mcp-server",
        "memoai/mcp-server"
      ],
      "enabled": true
    },
    // https://semgrep.dev/docs/mcp
    "semgrep": {
      "type": "local",
      "command": [
        "run",
        "-i",
        "--rm",
        "semgrep/semgrep",
        "semgrep",
        "mcp",
        "-t",
        "stdio"
      ],
      "enabled": false
    },
    // https://playwright.dev/
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": false
    },
    // https://vitest.dev/
    "vitest": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@djankies/vitest-mcp"
      ],
      "enabled": false
    },
    // https://github.com/modelcontextprotocol/servers/tree/main/src/sequentialthinking
    "sequentialthinking": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--name",
        "chiropraxiV2-sequential-thinking",
        "-i",
        "--rm",
        "mcp/sequentialthinking"
      ],
      "enabled": true
    },
    // https://github.com/modelcontextprotocol/servers/tree/main/src/memory
    "memory": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "-v",
        "claude-memory-chiropraxiV2:/app/dist",
        "--name",
        "chiropraxiV2-memory",
        "--rm",
        "mcp/memory"
      ],
      "enabled": false
    }
  },
  "permission": {
    "skill": {
      "sequential-thinking": "allow",
      "memory": "allow"
    }
  }
}